<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - HEdClass</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css?v=2">
</head>

<body>
    
     
<div class="login-wrap">
            <div class="loginContainer">

                <div class="text-center mb-4">
                    <h1 id="loginHead">Welcome to HEdClass</h1>
                    <p>Please log in to access the dashboard and manage student classifications.</p>
                </div>
                <div class="card mx-auto">
                    <img src="/assets/login.png" alt="Login Icon" class="card-img-top-fluid"
                        style="max-width: 100px; margin: 20px auto 0;">
                    <div class="card-body">
                        <h3 class="card-title">Login</h3>

                        <% if (error) { %>
                            <div class="alert alert-danger">
                                <%= error %>
                            </div>
                            <% } %>

                                <form action="/login" method="POST" class="login-form">
                                    <div class="mb-3">
                                        <label for="email" class="form-label">Email</label>
                                        <input type="email" class="form-control" id="email" name="email" required
                                            placeholder="admin@hedclass.demo">
                                    </div>
                                    <div class="mb-3">
                                        <label for="password" class="form-label">Password</label>
                                        <input type="password" class="form-control" id="password" name="password"
                                            required placeholder="Enter your password">
                                    </div>
                                    <button type="submit" class="btn btn-primary">Login</button>
                                </form>
                    </div>

                </div>

                <aside class="demo-note" aria-label="Demo credentials for reviewers">
                    <h2 class="demo-note-title">Reviewer / Demo Access</h2>
                    <p class="demo-note-sub">Sign in with any sample account:</p>

                    <div class="demo-cred">
                        <span class="demo-cred-role">Admin</span>
                        <span class="demo-cred-vals"><code>admin@hedclass.demo</code> &middot; <code>admin123</code></span>
                    </div>
                    <div class="demo-cred">
                        <span class="demo-cred-role">Officer</span>
                        <span class="demo-cred-vals"><code>officer1@hedclass.demo</code> &middot; <code>officer123</code></span>
                    </div>
                    <div class="demo-cred">
                        <span class="demo-cred-role">Officer</span>
                        <span class="demo-cred-vals"><code>officer2@hedclass.demo</code> &middot; <code>officer456</code></span>
                    </div>

                    <p class="demo-note-foot">🔒 Demo logins are shared on purpose. New users you create are stored
                        with a <strong>bcrypt-hashed</strong> password &mdash; never plain text.</p>
                </aside>
            </div>
</div>
</body>

</html>