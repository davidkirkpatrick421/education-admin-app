<%- include('../partials/head', {title: `Override Classification - ${student.first_name} ${student.surname}`}) %>
<%- include('../partials/nav') %>

<a href="/officer/students/<%= student.id %>?programme=<%= programmeId %> " class="btn btn-secondary">Back to Student Detail</a>

    <% if (error) { %>
        <div class="alert alert-warning"><%= error %></div>
    <% } %>

    <h2 class="mb-4">Override Classification for <%= student.first_name %> <%= student.surname %></h2>

<form action="/officer/students/<%= student.id %>/classify/override?programme=<%= programmeId %>" method="POST">
    <div class="mb-3">
        <label class="form-label">New Classification</label>
        <select name="classification_code" class="form-select" required>
            <option selected>Select classification...</option>
            <option value="1st">1st - First Class</option>
            <option value="2:1">2:1 - Upper Second Class</option>
            <option value="2:2">2:2 - Lower Second Class</option>
            <option value="3rd">3rd - Third Class</option>
            <option value="fail">Fail</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Reason for Override</label>
        <textarea name="override_rationale" class="form-control" rows="4" required placeholder="Provide Justification"></textarea>
        <div class="form-text">This reason will be recorded for auditing purposes.</div>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Submit Override</button>
        <a href="/officer/students/<%= student.id %>?programme=<%= programmeId %>" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>


<%- include('../partials/footer') %>
