<%- include('../partials/head', {title: 'Students' }) %>
    <%- include('../partials/nav') %>

        <% const totalStudents=students.length; %>
            <% const confirmedCount=students.filter(s=> s.confirmed_at).length; %>

                <% if (error) { %>
                    <div class="alert alert-warning">
                        <%= error %>
                    </div>
                    <% } %>

                        <div class="container-fluid mt-4 px-4 programme-content">

                            <h1>Students</h1>
                            <div class="programme-buttons d-flex flex-wrap gap-2 mb-3">
                                <a href="/officer/dashboard" class="btn btn-secondary">Back to Dashboard</a>
                                <a href="/officer/students/new?programme=<%= programmeId %>"
                                    class="btn btn-primary ">Add New Student</a>

                                <% if (confirmedCount> 0) { %>
                                    <% if (confirmedCount < totalStudents) { %>
                                        <a href="/officer/students/export?programme=<%= programmeId %>"
                                            class="btn btn-warning"
                                            onclick="return confirm('<%= confirmedCount %> of <%= totalStudents %> students confirmed. Export incomplete cohort?')">
                                            Export for Exam Board (<%= confirmedCount %>/<%= totalStudents %> confirmed)
                                        </a>
                                        <% } else { %>
                                            <a href="/officer/students/export?programme=<%= programmeId %>"
                                                class="btn btn-success">
                                                Export for Exam Board
                                            </a>
                                            <% } %>
                                                <% } %>
                            </div>

                            <div class="table-responsive">
                                <table class="table studentTable align-middle table-hover">
                                    <thead>
                                        <tr>
                                            <th>Student Number</th>
                                            <th>Name</th>
                                            <th>Academic Year</th>
                                            <th>MC</th>
                                            <th>Classification</th>
                                            
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (students.length===0) { %>
                                            <tr>
                                                <td>
                                                    No students in this programme yet.
                                                </td>
                                            </tr>
                                            <% } else { %>
                                                <% students.forEach(student=> { %>
                                                    <tr>
                                                        <td>
                                                            <%= student.student_number %>
                                                        </td>
                                                        <td>
                                                            <%= student.first_name %>
                                                                <%= student.surname %>
                                                        </td>
                                                        <td>
                                                            <%= student.academic_year %>
                                                        </td>
                                                        <td>
                                                            <% if (student.has_mc) { %>
                                                                <span class="badge bg-warning text-dark mc-notes" title="<%= student.mc_notes %>">Yes</span>
                                                                
                                                                <% } %>
                                                        </td>
                                                        <td>
                                                            <% if (student.classification_code) { %>
                                                                <% if (student.classification_code==='fail' ) { %>
                                                                    <span class="badge bg-danger">Fail</span>
                                                                    <% } else if (student.confirmed_at) { %>
                                                                        <span class="badge bg-success">
                                                                            <%= student.classification_code %> Confirmed
                                                                        </span>
                                                                        <% } else if (student.override_applied) { %>
                                                                            <span class="badge bg-warning">
                                                                                <%= student.classification_code %>
                                                                                    Override Applied
                                                                            </span>
                                                                            <% } else { %>
                                                                                <span class="badge bg-primary">
                                                                                    <%= student.classification_code %>
                                                                                        Pending Confirmation
                                                                                </span>
                                                                                <% } %>
                                                                                    <% } else if
                                                                                        (student.is_eligible===0) { %>
                                                                                        <span
                                                                                            class="badge bg-danger" title="<%= student.ineligibility_reason %>">Ineligible</span>
                                                                                        <% } else { %>
                                                                                            <span
                                                                                                class="badge bg-secondary">Pending</span>
                                                                                            <% } %>
                                                        </td>
                                        
                                                        <td>
                                                            <a href="/officer/students/<%= student.id %>?programme=<%= programmeId %>"
                                                                class="btn btn-sm btn-primary">View Details</a>
                                                        </td>

                                                    </tr>
                                                    <% }) %>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>


                        <%- include('../partials/footer') %>