<%- include('../partials/head', { title: 'Add New Officer' }) %>
    <%- include('../partials/nav') %>

        

        <% if (error) { %>
            <div class="alert alert-danger">
                <%= error %>
            </div>
            <% } %>

                <div class="container-fluid mt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <a href="/admin/officers" class="btn btn-secondary">Back to Officer List</a>
                        <h2 class="mb-0">Add New Officer</h2>
                    </div>

                    <div class="form-container">
                        <form action="/admin/officers" method="POST">
                            <div class="mb-3">
                                <label class="form-label">First Name</label>
                                <input type="text" name="first_name" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Surname</label>
                                <input type="text" name="surname" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" name="email" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" name="password" class="form-control" required>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Create Officer</button>
                                <a href="/admin/officers" class="btn btn-secondary">Cancel</a>
                            </div>
                    </div>
                    </form>
                </div>
                <%- include('../partials/footer') %>