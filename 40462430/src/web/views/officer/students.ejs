<%- include('../partials/head', {title: 'Students'}) %>
<%- include('../partials/nav') %>


<a href="/officer/students/new?programme=<%= programmeId %>" class="btn btn-success mb-3">Add New Student</a>

    <% if (error) { %>
        <div class="alert alert-warning"><%= error %></div>
    <% } %>
<table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Student Number</th>
                <th>Name</th>
                <th>Academic Year</th>
                <th>MC</th>
                <th>Classification</th>
            </tr>
        </thead>
        <tbody>
            <% if (students.length === 0) { %>
                <tr>
                    <td>
                        No students in this programme yet.
                    </td>
                </tr>
            <% } else { %>
                <% students.forEach(student => { %>
                <tr>
                    <td><%= student.student_number %></td>
                    <td><%= student.first_name %> <%= student.surname %></td>
                    <td><%= student.academic_year %></td>
                    <td>
                        <% if (student.has_mc) { %>
                            <span class="badge bg-warning text-dark">MC</span>
                            <small class="text-muted"><%= student.mc_notes %></small>
                        <% } %>
                    </td>
                    <td>
                        <span class="badge bg-secondary">Pending</span>
                    </td>
                    <td>
                        <a href="/officer/students/<%= student.id %>?programme=<%= programmeId %>" class="btn btn-sm btn-outline-primary">View Details</a>
                    </td>
                    
                </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>

<%- include('../partials/footer') %>