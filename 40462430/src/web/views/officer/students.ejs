<%- include('../partials/head', {title: 'Students'}) %>
<%- include('../partials/nav') %>


<h1>Students</h1>
<div class="d-flex gap-2">
    <a href="/officer/dashboard" class="btn btn-secondary mb-3">Back to Dashboard</a>  
<a href="/officer/students/new?programme=<%= programmeId %>" class="btn btn-success mb-3">Add New Student</a>
<% if (students.some(s => s.confirmed_at)) { %>
    <a href="/officer/students/export?programme=<%= programmeId %>" class="btn btn-outline-primary mb-3">Export CSV for Exam Board</a>
<% } %>
</div>



    <% if (error) { %>
        <div class="alert alert-warning"><%= error %></div>
    <% } %>
<table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Student Number</th>
                <th>Name</th>
                <th>Academic Year</th>
                <th>Mitigating Circumstances</th>
                <th>Classification</th>
            </tr>
        </thead>
        <tbody>
            <% if (students.length === 0) { %>
                <tr>
                    <td>
                        No students in this programme yet.
                    </td>
                </tr>
            <% } else { %>
                <% students.forEach(student => { %>
                <tr>
                    <td><%= student.student_number %></td>
                    <td><%= student.first_name %> <%= student.surname %></td>
                    <td><%= student.academic_year %></td>
                    <td>
                        <% if (student.has_mc) { %>
                            <span class="badge bg-warning text-dark">MC</span>
                            <small class="text-muted"><%= student.mc_notes %></small>
                        <% } %>
                    </td>
                    <td>
                        <% if (student.classification_code) { %>
                            <% if (student.classification_code === 'fail') { %>
                                <span class="badge bg-danger">Fail</span>
                            <% } else if (student.confirmed_at) { %>
                            <span class="badge bg-success">
                                <%= student.classification_code %> Confirmed</span>
                        <% } else if (student.override_applied) { %>
                            <span class="badge bg-warning">
                                <%= student.classification_code %> Override Applied</span>
                        <% } else { %>
                            <span class="badge bg-primary">
                                <%= student.classification_code %> Pending Confirmation</span>
                            <% } %>
                        <% } else if (student.is_eligible === 0) { %>
                            <span class="badge bg-danger">Ineligible</span>
                        <% } else { %>
                            <span class="badge bg-secondary">Pending</span>
                        <% } %>
                    </td>
                    <td>
                        <a href="/officer/students/<%= student.id %>?programme=<%= programmeId %>" class="btn btn-sm btn-outline-primary">View Details</a>
                    </td>
                    
                </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>

<%- include('../partials/footer') %>