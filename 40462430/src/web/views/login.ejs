<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - HEdClass</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>

<body>
    <div class="img-BG">
        <div class="img-BG-overlay">


            <div class="loginContainer">

                <div class="text-center mb-4">
                    <h1 id="loginHead">Welcome to HEdClass</h1>
                    <p>Please log in to access the dashboard and manage student classifications.</p>
                </div>
                <div class="card mx-auto">
                    <img src="/assets/login.png" alt="Login Icon" class="card-img-top-fluid"
                        style="max-width: 100px; margin: 20px auto 0;">
                    <div class="card-body">
                        <h3 class="card-title">Login</h3>

                        <% if (error) { %>
                            <div class="alert alert-danger">
                                <%= error %>
                            </div>
                            <% } %>

                                <form action="/login" method="POST" class="login-form">
                                    <div class="mb-3">
                                        <label for="email" class="form-label">Email</label>
                                        <input type="email" class="form-control" id="email" name="email" required
                                            placeholder="your@qub.ac.uk">
                                    </div>
                                    <div class="mb-3">
                                        <label for="password" class="form-label">Password</label>
                                        <input type="password" class="form-control" id="password" name="password"
                                            required placeholder="Enter your password">
                                    </div>
                                    <button type="submit" class="btn btn-primary">Login</button>
                                </form>
                    </div>

                </div>
            </div>
        </div>
    </div>

</body>

</html>