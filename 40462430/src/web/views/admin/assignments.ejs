<%- include('../partials/head', { title: 'Assignments' }) %>
<%- include('../partials/nav') %>

<h2>Officer Assignments</h2>
        <a href="/admin/assignments-new" class="btn btn-primary">New Assignment</a>
    </div>

    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Officer</th>
                <th>Email</th>
                <th>Programme</th>
                <th>Code</th>
                <th>Status</th>
                <th>Assigned</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% assignments.forEach(assignment => { %>
            <tr>
                <td><%= assignment.first_name %> <%= assignment.surname %></td>
                <td><%= assignment.email %></td>
                <td><%= assignment.programme_title %></td>
                <td><code><%= assignment.code %></code></td>
                <td>
                    <% if (assignment.is_active) { %>
                        <span class="badge bg-success">Active</span>
                    <% } else { %>
                        <span class="badge bg-secondary">Inactive</span>
                    <% } %>
                </td>
                <td><%= new Date(assignment.assigned_at).toLocaleDateString('en-GB') %></td>
                <td>
                    <% if (assignment.is_active) { %>
                        <form action="/admin/assignments/<%= assignment.id %>/remove" method="POST" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Remove this assignment?')">
                                Remove
                            </button>
                        </form>
                    <% } %>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>

<%- include('../partials/footer') %>