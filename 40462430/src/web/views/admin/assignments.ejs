<%- include('../partials/head', { title: 'Assignments' }) %>
    <%- include('../partials/nav') %>

        <div class="container-fluid mt-4 px-4 assignments">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a href="/admin/dashboard" class="btn btn-secondary">Back to Dashboard</a>
                <h1>Officer Assignments</h1>
            </div>
            <a href="/admin/assignments-new" class="btn btn-primary mb-3">New Assignment</a>


            <div class="table-responsive">
                <table class="table table-hover assignments-table">
                    <thead>
                        <tr>
                            <th>Officer</th>
                            <th>Email</th>
                            <th>Programme</th>
                            <th>Code</th>
                            <th>Status</th>
                            <th>Assigned</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% assignments.forEach(assignment=> { %>
                            <tr>
                                <td>
                                    <%= assignment.first_name %>
                                        <%= assignment.surname %>
                                </td>
                                <td>
                                    <%= assignment.email %>
                                </td>
                                <td>
                                    <%= assignment.programme_title %>
                                </td>
                                <td>
                                    <%= assignment.code %>
                                </td>
                                <td>
                                    <% if (assignment.is_active) { %>
                                        <span class="badge bg-success">Active</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Inactive</span>
                                            <% } %>
                                </td>
                                <td>
                                    <%= new Date(assignment.assigned_at).toLocaleDateString('en-GB') %>
                                </td>
                                <td>
                                    <% if (assignment.is_active) { %>
                                        <form action="/admin/assignments/<%= assignment.id %>/remove" method="POST" style="display: inline;">
                                            <button type="submit" class="btn btn-sm btn-danger"
                                                onclick="return confirm('Remove this assignment?')">
                                                Remove
                                            </button>
                                        </form>
                                        <% } %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>

        </div>

        <%- include('../partials/footer') %>