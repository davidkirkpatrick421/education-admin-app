# Copy to .env and fill in real values. Never commit the real .env.

# development | production
NODE_ENV=development

# Web (presentation) server port
WEB_PORT=4000
# API (data/business) server port
API_PORT=5000
# Base URL the web tier uses to reach the API.
# Local dev: http://localhost:5000   |   Docker compose: http://api:5000
API_URL=http://localhost:5000

# PostgreSQL connection string (Supabase: Settings -> Database -> Connection string)
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# Secret for signing session cookies (generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
SESSION_SECRET=replace_me

# Shared secret the web tier uses to sign internal JWTs for the API (generate the same way, distinct value)
INTERNAL_JWT_SECRET=replace_me
